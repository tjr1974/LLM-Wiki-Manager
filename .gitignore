# --- Python & packaging ---
.venv/
venv/
ENV/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# --- Secrets & local configuration (never commit) ---
.env
.env.*
!.env.example
# direnv: local env hooks often export secrets or absolute paths (see README: never commit .env)
.envrc
.direnv/

# --- OS / editor ---
.DS_Store
Thumbs.db
*~
*.swp
*.swo
*.bak

# Jupyter (local notebooks or ad-hoc analysis beside the repo)
.ipynb_checkpoints/

# Cursor: ignore local workspace files; un-ignore `rules/` when sharing team guidance
# (Git ignores children of an excluded parent unless each parent is re-included.)
.cursor/**
!.cursor/
!.cursor/rules/
!.cursor/rules/**

# Maintainer private prompts (see schema/protected-paths.md; also listed in .cursorignore)
dev_prompts.txt

# --- Generated lint logs ---
logs/

# Optional hub rollup from `make wiki-hub` (not tracked in this scaffold; `git add -f` to commit a curated copy)
wiki/synthesis/hub-index.md

# --- Fork-built static exports (templates live in-repo; baked HTML is local) ---
human/site/

# --- Machine-local automation (embed absolute repo/interpreter paths in JSON) ---
ai/runtime/autopilot.status.json
ai/runtime/daemon.heartbeat.json

# Fork comparison tooling output (embeds absolute parent_root / child_root from make fork-delta CHILD='...')
ai/runtime/fork_delta_*.min.json
ai/runtime/fork_delta_*.md
ai/runtime/fork-delta*.json

# Wiki Manager per-child fork-delta bundles (see schema/wiki-manager.md)
ai/runtime/manager/

# --- Autopilot runtime streams ---
ai/runtime/.autopilot.runtime.lock
ai/runtime/autopilot.ops.ndjson

# Ingest operation log (append-only; embeds absolute paths and subprocess argv)
ai/runtime/ingest.ops.ndjson

# --- Local query / rollup outputs (see README: writeback_artifact, coverage matrix paths) ---
ai/artifacts/

# Post-deploy HTTP smoke (optional; may reference private base URLs — regenerate locally after deploy)
ai/runtime/deployed_site_smoke.min.json

# --- Optional local junk / editor ---
.idea/
*.log
node_modules/

# Drop confidential ingest files under raw/inbox/ without committing (tracked fixtures stay in git)
raw/inbox/**
!raw/inbox/queue-fixture.txt

# Merge / patch fallout
*.orig
*.rej

# Optional local maintainer diagrams / screenshots at repo root (large binaries)
/llm_wiki_*.png
/llm_wiki_*.jpg
/llm_wiki_*.jpeg

# Optional local scratch at repo root only
/scratch/
/tmp/

# Empty placeholder in this scaffold; keep local experiments out of git
temp/

# Property-based tests (if added later)
.hypothesis/

# --- Avoid accidental commit of common key material ---
*.pem
*.p12
id_rsa
id_ed25519
